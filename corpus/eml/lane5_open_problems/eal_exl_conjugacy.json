    "variant_strategy": null,
    "statement": {
      "informal": "EAL ↔ EXL conjugacy via exp. If f(x) = exp(x) + ln(x) is the EAL self-map and g(y) = exp(y)·ln(y) is the EXL self-map, then on the positive reals g(exp(x)) = exp(f(x)). Encodes the identity exp(exp(x)+ln(x)) = exp(exp(x))·x = exp(exp(x))·ln(exp(x)).",
      "formal_lean": "theorem eal_exl_conjugacy (x : ℝ) (hx : 0 < x) :\n    Real.exp (Real.exp x) * Real.log (Real.exp x)\n      = Real.exp (Real.exp x + Real.log x) := by\n  rw [Real.exp_add, Real.log_exp, Real.exp_log hx]",
